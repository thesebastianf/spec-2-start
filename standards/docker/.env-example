# ===================================
# .env-example
# Complete with all required variables
# Contains placeholder / random values (no real secrets)
# Copy to .env for local development
# ===================================

# ── App ──────────────────────────────
NODE_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000
APP_SECRET=replace-with-random-secret-min-32-chars

# ── Database (PostgreSQL) ────────────
POSTGRES_USER=local_user
POSTGRES_PASSWORD=change_me_123
POSTGRES_DB=app_dev
POSTGRES_PORT=5432
DATABASE_URL=postgresql://local_user:change_me_123@postgres:5432/app_dev

# ── Redis ────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ── Email (optional) ────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=

# ── External APIs (optional) ────────
# API_KEY=your-api-key-here
